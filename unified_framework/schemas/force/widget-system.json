{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://idfwu.dev/schemas/force/widget-system.json",
  "title": "FORCE Widget System Schema",
  "description": "Comprehensive widget definition and configuration schema for monitoring dashboards",
  "definitions": {
    "widgetSize": {
      "type": "string",
      "enum": ["normal", "expanded", "condensed", "minimal", "maximized"],
      "default": "normal"
    },
    "widgetColor": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$|^rgb\\(\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3}\\)$"
        },
        "secondary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$|^rgb\\(\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3}\\)$"
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$|^rgb\\(\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3}\\)$"
        },
        "tint": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Tint factor for color variations"
        },
        "shade": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Shade factor for color variations"
        }
      }
    },
    "widgetIcon": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Icon name from icon library"
        },
        "position": {
          "type": "string",
          "enum": ["left", "right", "top", "bottom", "center"],
          "default": "left"
        },
        "size": {
          "type": "string",
          "enum": ["small", "medium", "large", "xlarge"],
          "default": "medium"
        },
        "color": {
          "type": "string",
          "description": "Override color for icon"
        }
      }
    },
    "widgetTitle": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "Widget title text"
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "size": {
          "type": "string",
          "enum": ["small", "normal", "large", "xlarge"],
          "default": "normal"
        },
        "position": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right", "tab", "none"],
          "default": "top"
        },
        "icon": {
          "$ref": "#/definitions/widgetIcon"
        },
        "customStyle": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "widgetDecoration": {
      "type": "object",
      "properties": {
        "border": {
          "type": "object",
          "properties": {
            "visible": {"type": "boolean", "default": true},
            "style": {
              "type": "string",
              "enum": ["solid", "dashed", "dotted", "double", "groove", "ridge"],
              "default": "solid"
            },
            "width": {"type": "integer", "minimum": 0, "maximum": 10, "default": 1},
            "color": {"type": "string"},
            "radius": {"type": "integer", "minimum": 0, "maximum": 50, "default": 8}
          }
        },
        "shadow": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "x": {"type": "integer", "default": 0},
            "y": {"type": "integer", "default": 2},
            "blur": {"type": "integer", "default": 10},
            "spread": {"type": "integer", "default": 0},
            "color": {"type": "string", "default": "rgba(0,0,0,0.2)"}
          }
        },
        "background": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["solid", "gradient", "pattern", "image"],
              "default": "solid"
            },
            "value": {"type": "string"},
            "opacity": {"type": "number", "minimum": 0, "maximum": 1, "default": 1}
          }
        }
      }
    },
    "dataPoint": {
      "type": "object",
      "properties": {
        "key": {"type": "string"},
        "label": {"type": "string"},
        "value": {},
        "unit": {"type": "string"},
        "format": {"type": "string"},
        "visible": {"type": "boolean", "default": true},
        "icon": {"$ref": "#/definitions/widgetIcon"},
        "prepend": {"type": "string"},
        "append": {"type": "string"},
        "style": {"type": "object"}
      }
    }
  },
  "type": "object",
  "required": ["widgetId", "type", "version"],
  "properties": {
    "widgetId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier for the widget"
    },
    "type": {
      "type": "string",
      "enum": [
        "metric-card",
        "chart-line",
        "chart-bar",
        "chart-pie",
        "chart-area",
        "chart-scatter",
        "chart-bubble",
        "gauge",
        "heatmap",
        "table",
        "log-viewer",
        "trace-tree",
        "flame-graph",
        "3d-graph",
        "timeline",
        "alert-list",
        "dependency-map",
        "sankey-diagram",
        "treemap",
        "funnel-chart",
        "radar-chart",
        "status-grid",
        "sparkline-grid",
        "event-stream",
        "task-history"
      ],
      "description": "Widget type"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "layout": {
      "type": "object",
      "required": ["position", "dimensions"],
      "properties": {
        "position": {
          "type": "object",
          "properties": {
            "x": {"type": "integer", "minimum": 0},
            "y": {"type": "integer", "minimum": 0},
            "z": {"type": "integer", "minimum": 0, "default": 0}
          }
        },
        "dimensions": {
          "type": "object",
          "properties": {
            "width": {"type": "integer", "minimum": 1, "maximum": 24},
            "height": {"type": "integer", "minimum": 1, "maximum": 24},
            "minWidth": {"type": "integer", "minimum": 1},
            "minHeight": {"type": "integer", "minimum": 1},
            "maxWidth": {"type": "integer"},
            "maxHeight": {"type": "integer"}
          }
        },
        "gridSize": {
          "type": "integer",
          "enum": [12, 16, 20, 24],
          "default": 12,
          "description": "Grid granularity for widget sizing"
        },
        "resizable": {
          "type": "boolean",
          "default": true
        },
        "draggable": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "display": {
      "type": "object",
      "properties": {
        "size": {"$ref": "#/definitions/widgetSize"},
        "title": {"$ref": "#/definitions/widgetTitle"},
        "color": {"$ref": "#/definitions/widgetColor"},
        "decoration": {"$ref": "#/definitions/widgetDecoration"},
        "visibility": {
          "type": "object",
          "properties": {
            "visible": {"type": "boolean", "default": true},
            "showOnHover": {"type": "boolean", "default": false},
            "opacity": {"type": "number", "minimum": 0, "maximum": 1, "default": 1},
            "conditions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "field": {"type": "string"},
                  "operator": {"type": "string", "enum": ["==", "!=", ">", "<", ">=", "<=", "contains", "regex"]},
                  "value": {},
                  "action": {"type": "string", "enum": ["show", "hide", "disable"]}
                }
              }
            }
          }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "source": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["api", "websocket", "database", "cache", "computed", "static"]
            },
            "endpoint": {"type": "string"},
            "query": {"type": "string"},
            "refresh": {
              "type": "object",
              "properties": {
                "interval": {"type": "integer", "minimum": 0},
                "mode": {
                  "type": "string",
                  "enum": ["polling", "push", "manual", "live"],
                  "default": "polling"
                }
              }
            }
          }
        },
        "transform": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["filter", "map", "reduce", "aggregate", "sort", "limit", "join"]
              },
              "config": {"type": "object"}
            }
          }
        },
        "dataPoints": {
          "type": "array",
          "items": {"$ref": "#/definitions/dataPoint"}
        }
      }
    },
    "interactions": {
      "type": "object",
      "properties": {
        "clickable": {"type": "boolean", "default": true},
        "hoverable": {"type": "boolean", "default": true},
        "selectable": {"type": "boolean", "default": false},
        "draggable": {"type": "boolean", "default": false},
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event", "action"],
            "properties": {
              "event": {
                "type": "string",
                "enum": ["click", "dblclick", "hover", "select", "contextmenu", "drag", "drop"]
              },
              "action": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["navigate", "filter", "drill", "maximize", "minimize", "refresh", "export", "custom"]
                  },
                  "target": {"type": "string"},
                  "parameters": {"type": "object"}
                }
              }
            }
          }
        },
        "tooltip": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "template": {"type": "string"},
            "position": {
              "type": "string",
              "enum": ["auto", "top", "bottom", "left", "right"],
              "default": "auto"
            },
            "delay": {"type": "integer", "default": 500}
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "targetWidget"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["drill-down", "filter", "highlight", "sync", "cascade", "aggregate", "parent-child"]
          },
          "targetWidget": {"type": "string"},
          "bidirectional": {"type": "boolean", "default": false},
          "config": {
            "type": "object",
            "properties": {
              "field": {"type": "string"},
              "mapping": {"type": "object"},
              "propagate": {"type": "boolean", "default": true}
            }
          }
        }
      }
    },
    "customization": {
      "type": "object",
      "properties": {
        "allowEdit": {"type": "boolean", "default": true},
        "editableProperties": {
          "type": "array",
          "items": {"type": "string"},
          "default": ["title", "color", "size", "dataPoints"]
        },
        "presets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "config": {"type": "object"}
            }
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "accessibility": {
      "type": "object",
      "properties": {
        "ariaLabel": {"type": "string"},
        "ariaDescribedBy": {"type": "string"},
        "keyboardNavigation": {"type": "boolean", "default": true},
        "screenReaderMode": {"type": "boolean", "default": false},
        "highContrast": {"type": "boolean", "default": false},
        "focusIndicator": {"type": "boolean", "default": true}
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created": {"type": "string", "format": "date-time"},
        "modified": {"type": "string", "format": "date-time"},
        "author": {"type": "string"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "description": {"type": "string"},
        "documentation": {"type": "string", "format": "uri"}
      }
    }
  }
}