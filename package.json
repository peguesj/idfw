{
  "name": "idfwu",
  "version": "1.0.0",
  "description": "IDFWU - IDEA Framework Unified: Unification of IDFW and Dev Sentinel into a comprehensive development framework",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist build coverage .cache",
    "dev": "tsc --watch",
    "precommit": "npm run lint && npm run format:check && npm run type-check",
    "prepare": "npm run build"
  },
  "keywords": [
    "idfw",
    "idea-framework",
    "dev-sentinel",
    "yung",
    "agent-orchestration",
    "mcp",
    "schema-management",
    "linear-integration"
  ],
  "author": "Jeremiah Pegues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/[to-be-created]/idfw-unified.git"
  },
  "bugs": {
    "url": "https://github.com/[to-be-created]/idfw-unified/issues"
  },
  "homepage": "https://linear.app/pegues-innovations/project/idfwu-idea-framework-unified-4d649a6501f7",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}